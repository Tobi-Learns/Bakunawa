# Copy to .env and fill in. Points at Bakunawa's dedicated Supabase project
# (migrated off the shared StellarPay project 2026-07-09).
# SESSION_URL     = pooler session mode, port 5432 (CLI/DDL; blocked by some VPNs)
# TRANSACTION_URL = pooler transaction mode, port 6543 (runtime queries + DDL script)
# DIRECT_URL      = direct db host, port 5432 (usually blocked by Supabase network rules)
SESSION_URL=""
TRANSACTION_URL=""
DIRECT_URL=""
# Auth for /api/indexer/run (cron-job.org sends: Authorization: Bearer <value>)
BAKUNAWA_CRON_SECRET=""
# Auth for /api/admin/* metadata routes (typed into the /admin UI once per session)
BAKUNAWA_ADMIN_SECRET=""

# 5c: Auth.js (Google sign-in). Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
