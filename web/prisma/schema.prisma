// Bakunawa read-cache + registry. THE CHAIN IS THE SOURCE OF TRUTH — these
// tables cache on-chain state for fast browsing and hold the off-chain
// metadata the contract deliberately doesn't store (title, category, display
// curve per S7). The indexer (src/lib/indexer.ts) is the only writer.
//
// NOTE: tables are prefixed Bakunawa* — legacy of an earlier shared-project
// arrangement. As of 2026-07-09 they live in Bakunawa's own dedicated Supabase
// project (migrated off StellarPay's; the prefix is kept to avoid a churn).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Market {
  id          BigInt   @id // on-chain u64 market id
  sideA       String
  sideB       String
  oracle      String // "Admin" | "Reflector"
  asset       String? // Reflector asset symbol
  rungs       Int[]
  closeTs     Int
  settleTs    Int
  rakeBps     Int
  minPool     BigInt   @default(0)
  baseline    String? // i128 as string
  ticketA     String? // v4: side-0 ticket SAC
  ticketB     String? // v4: side-1 ticket SAC
  status      String // on-chain: Open | Settled | Cancelled
  pool        BigInt   @default(0) // cached total staked (stroops)
  // outcome cache (Settled only)
  winner      Int?
  margin      Int?
  losingPool  BigInt?
  rakeAmount  BigInt?
  // off-chain metadata (curator-managed, Phase 1.7)
  title       String?
  description String?
  category    String? // "crypto" | "nba" | ...
  curve       Json? // S7: display/context curve table, never a settlement input
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  positions   Position[]
  exits       Exit[]

  @@index([status])
  @@map("BakunawaMarket")
}

model Position {
  id       String   @id // RPC event id — idempotent inserts
  marketId BigInt
  market    Market  @relation(fields: [marketId], references: [id])
  predictor String
  side      Int
  rung      Int
  stake     BigInt
  shares    BigInt   @default(0) // 5a: DPM shares issued (mint/conviction events publish them; 0 = pre-5a row, basis unknown)
  txHash    String
  ledger    Int
  at        DateTime

  @@index([predictor])
  @@index([marketId])
  @@map("BakunawaPosition")
}

/// 5a: exit events (redeem/claim) — realized P&L legs for the per-address
/// profile. Same idempotence as Position: RPC event id is the PK.
model Exit {
  id       String   @id // RPC event id
  marketId BigInt
  market   Market   @relation(fields: [marketId], references: [id])
  holder   String
  kind     String // "redeem" | "claim"
  side     Int? // redeem only (claim pays all winning convictions at once)
  shares   BigInt? // redeem only: share amount returned to custody
  payout   BigInt
  txHash   String
  ledger   Int
  at       DateTime

  @@index([holder])
  @@index([marketId])
  @@map("BakunawaExit")
}

/// 5c: Google-bound profile (Auth.js, JWT sessions — no DB session tables).
/// The binder: groups wallet addresses under one account (5d) and carries the
/// profile identity. Deliberate privacy linkage (Phase 5 decision 6).
model User {
  id          String   @id @default(uuid())
  googleSub   String   @unique
  email       String
  name        String? // from Google at first sign-in
  image       String? // Google avatar URL
  displayName String? // user-editable, shown in-app
  createdAt   DateTime @default(now())
  wallets     ProfileWallet[]

  @@map("BakunawaUser")
}

/// 5d: bound wallet addresses per user (bind-on-connect, no signature —
/// Phase 5 decision 4).
model ProfileWallet {
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address String
  label   String?
  boundAt DateTime @default(now())

  @@id([userId, address])
  @@index([address])
  @@map("BakunawaProfileWallet")
}

model IndexerCursor {
  id         Int      @id @default(1)
  lastLedger Int
  updatedAt  DateTime @updatedAt

  @@map("BakunawaCursor")
}

/// Reflector price samples (1.9c) — written by the indexer cron for every
/// asset with an open Reflector market, plus on-demand backfill from the
/// feed's price(ts) history. Timestamps are aligned to the feed resolution.
model PriceSample {
  id    String @id // `${asset}-${ts}`
  asset String
  ts    Int
  price String // i128 stroops-of-14dp as string

  @@index([asset, ts])
  @@map("BakunawaPriceSample")
}
